{
  "expo": {
    "name": "Pointo",
    "slug": "pointo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pointo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pointo.app",
      "associatedDomains": ["applinks:pointo.app"],
      "infoPlist": {
        "NSMotionUsageDescription": "Pointo uses your step count to award walk-to-earn rewards."
      }
    },
    "android": {
      "package": "com.pointo.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "pointo.app", "pathPrefix": "/join" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
